API_BASE=__API_BASE__

SYSTEM_ID=__SYSTEM_ID__
DEVICE_ID=__DEVICE_ID__

# Current power-controller interface.
# POWER_CONTROLLER_BACKEND options: auto, lifepo4wered, wittypi, none
ENABLE_POWER_CONTROLLER=__ENABLE_POWER_CONTROLLER__
POWER_CONTROLLER_BACKEND=__POWER_CONTROLLER_BACKEND__

# Legacy compatibility. Prefer ENABLE_POWER_CONTROLLER for new code.
ENABLE_WITTYPI=__ENABLE_WITTYPI__

SYSTEM_DEPLOYED_UNDERWATER=false
ALWAYS_OFF_CHECKIN_SEC=900

BOOT_SETTLE_SEC=1
WAKE_BUFFER_SEC=30
LINUX_BOOT_WAIT_SEC=20
GPS_MAX_WAIT_SEC=60
LTE_MAX_WAIT_SEC=60
RESLEEP_MARGIN_SEC=20
STARTUP_WAIT_POLL_SEC=5
SHUTDOWN_DELAY_SEC=5

DEFAULT_CAPTURE_INTERVAL_SEC=300
CONFIG_POLL_SEC=60

LTE_PROBE_HOST=1.1.1.1
LTE_PROBE_COUNT=1
LTE_PROBE_TIMEOUT_SEC=3

ENABLE_REMOTE_CYCLE_LOGS=true
REMOTE_CYCLE_LOG_MAX_LINES=400

# Keep each field system's cached cloud config independent.
SYSTEM_CONFIG_CACHE_PATH=__SYSTEM_CONFIG_CACHE_PATH__
LOCAL_IMAGE_DIR=/var/lib/nereus/images
UNSENT_MANIFEST_PATH=/var/lib/nereus/images/unsent_manifest.jsonl

# System health / BME280 internal enclosure environment polling.
ENABLE_SYSTEM_HEALTH_MONITORING=true
HEALTH_SAMPLE_RATE_HZ=2.0
HEALTH_LOG_DIR=/var/log/nereus/health
ENABLE_BME280_INTERNAL_ENV=true
BME280_I2C_BUS=1
BME280_I2C_ADDRESSES=0x77,0x76

# External/removable media storage.
# The external card does not need a fixed label; the agent/test detects usable removable media.
ENABLE_EXTERNAL_MEDIA_STORAGE=true
EXTERNAL_MEDIA_MOUNT_POINT=/mnt/nereus-media
EXTERNAL_MEDIA_IMAGE_DIR=/mnt/nereus-media/images
REQUIRE_EXTERNAL_MEDIA_ARCHIVE=false
ALLOW_TRANSIENT_CAPTURE_WITHOUT_EXTERNAL_MEDIA=true
TRANSIENT_IMAGE_DIR=/var/tmp/nereus-transient
DELETE_TRANSIENT_AFTER_UPLOAD=true
EXTERNAL_MEDIA_MIN_FREE_BYTES=104857600
EXTERNAL_MEDIA_MOUNT_UID=1000
EXTERNAL_MEDIA_MOUNT_GID=1000
